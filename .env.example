# ── Required — Get your FREE key at https://console.groq.com ─────────────────
GROQ_API_KEY=gsk_...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./audit_agent.db

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── Groq LLM (free tier) ──────────────────────────────────────────────────────
# Available free models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.1
GROQ_RATE_LIMIT_DELAY=2.0   # 2s between calls keeps you under 30 req/min free limit

# ── OCR for image evidence (optional) ─────────────────────────────────────────
# Windows: set path to tesseract.exe after installing from https://github.com/UB-Mannheim/tesseract/wiki
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
